{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "VN Fusion Character Arcs",
  "type": "object",
  "required": ["arcs"],
  "properties": {
    "arcs": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["id", "character_id", "start_mask", "current_state", "pressure", "target_shift"],
        "properties": {
          "id": { "type": "string", "pattern": "^ARC_[A-Za-z0-9_]+$" },
          "character_id": { "type": "string" },
          "start_mask": { "type": "string" },
          "current_state": { "type": "string" },
          "pressure": { "type": "string" },
          "target_shift": { "type": "string" },
          "allowed_regression": { "type": "string" },
          "scene_beats": {
            "type": "object",
            "additionalProperties": { "type": "string" }
          }
        },
        "additionalProperties": true
      }
    }
  },
  "additionalProperties": true
}
