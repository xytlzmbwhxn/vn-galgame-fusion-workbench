{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "VN Fusion Workbench Character Card V2 Export",
  "type": "object",
  "required": ["spec", "spec_version", "data"],
  "properties": {
    "spec": {
      "const": "chara_card_v2"
    },
    "spec_version": {
      "type": "string"
    },
    "data": {
      "type": "object",
      "required": ["name", "description", "personality", "scenario", "mes_example", "post_history_instructions", "character_book"],
      "properties": {
        "name": { "type": "string" },
        "description": { "type": "string" },
        "personality": { "type": "string" },
        "scenario": { "type": "string" },
        "first_mes": { "type": "string" },
        "mes_example": { "type": "string" },
        "creator_notes": { "type": "string" },
        "system_prompt": { "type": "string" },
        "post_history_instructions": { "type": "string" },
        "alternate_greetings": {
          "type": "array",
          "items": { "type": "string" }
        },
        "tags": {
          "type": "array",
          "items": { "type": "string" }
        },
        "creator": { "type": "string" },
        "character_version": { "type": "string" },
        "extensions": { "type": "object" },
        "character_book": {
          "type": "object",
          "required": ["entries"],
          "properties": {
            "name": { "type": "string" },
            "entries": {
              "type": "array",
              "items": {
                "type": "object",
                "required": ["keys", "content", "enabled", "insertion_order"],
                "properties": {
                  "keys": {
                    "type": "array",
                    "items": { "type": "string" }
                  },
                  "content": { "type": "string" },
                  "enabled": { "type": "boolean" },
                  "insertion_order": { "type": "integer" }
                }
              }
            }
          }
        }
      }
    }
  }
}
