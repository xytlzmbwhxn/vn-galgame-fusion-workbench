{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "VN Control Room Command",
  "type": "object",
  "required": [
    "id",
    "created_at",
    "updated_at",
    "status",
    "project_id",
    "action"
  ],
  "properties": {
    "id": {
      "type": "string",
      "minLength": 8
    },
    "created_at": {
      "type": "string"
    },
    "updated_at": {
      "type": "string"
    },
    "status": {
      "type": "string",
      "enum": [
        "queued",
        "running",
        "succeeded",
        "failed",
        "cancelled"
      ]
    },
    "project_id": {
      "type": "string"
    },
    "action": {
      "type": "string",
      "enum": [
        "draft_session",
        "validate",
        "deep_audit",
        "render_readable",
        "export_all",
        "character_brief",
        "style_contract",
        "quality_debt"
      ]
    },
    "scene": {
      "type": [
        "string",
        "null"
      ]
    },
    "script": {
      "type": [
        "string",
        "null"
      ]
    },
    "draft_name": {
      "type": [
        "string",
        "null"
      ]
    },
    "note": {
      "type": "string"
    },
    "result": {
      "type": [
        "object",
        "array",
        "string",
        "null"
      ]
    }
  },
  "additionalProperties": true
}
